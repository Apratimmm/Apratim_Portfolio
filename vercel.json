{
    "version": 2,
    "builds": [
        {
            "src": "main/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12"
            }
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "static"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "main/wsgi.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "main.settings"
    }
}